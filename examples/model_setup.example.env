# Local model/runtime interfaces for the full perception/VLM stack.
# Download model weights from the upstream projects and set these paths locally.

ACTIVASK_GROUNDINGDINO_MODEL=IDEA-Research/grounding-dino-base
ACTIVASK_SAM_MODEL_TYPE=vit_b
ACTIVASK_SAM_CHECKPOINT=/path/to/sam_vit_b_01ec64.pth
ACTIVASK_VLM_BASE_URL=http://127.0.0.1:8000/v1
ACTIVASK_VLM_MODEL=MiMo-VL-7B-RL-2508
